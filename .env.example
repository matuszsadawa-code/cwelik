# OpenClaw Trading Dashboard - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite database URL
# For local development: sqlite:///./db/trading_system.db
# For production: Use absolute path or configure external database
DATABASE_URL=sqlite:///./db/trading_system.db


# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================

# JWT Secret Key - MUST be changed in production!
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-here-change-in-production

# JWT Token Expiration (hours)
JWT_TOKEN_EXPIRE_HOURS=24

# Encryption Key for API key storage (Fernet key)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here-change-in-production


# ============================================================================
# EXCHANGE API KEYS - BYBIT
# ============================================================================

# Bybit Live Trading API Keys
# Get from: https://www.bybit.com/app/user/api-management
# Permissions: Read-only for monitoring, Trade for execution
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Bybit Demo/Testnet API Keys
# Get from: https://testnet.bybit.com/app/user/api-management
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=


# ============================================================================
# EXCHANGE API KEYS - BINANCE
# ============================================================================

# Binance API Keys
# Get from: https://www.binance.com/en/my/settings/api-management
# Permissions: Read-only for monitoring, Trade for execution
BINANCE_API_KEY=
BINANCE_API_SECRET=


# ============================================================================
# NEWS & SENTIMENT API KEYS
# ============================================================================

# CryptoPanic API Key (for crypto news sentiment)
# Get from: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# NewsAPI Key (alternative news source)
# Get from: https://newsapi.org/
NEWSAPI_KEY=


# ============================================================================
# POLYMARKET API KEYS (Optional)
# ============================================================================

# Polymarket API credentials (if using prediction markets integration)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_ENABLED=false
POLYMARKET_TESTNET=true


# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Origins (comma-separated)
# For development: http://localhost:3000,http://localhost:5173
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30
WS_HEARTBEAT_TIMEOUT=60

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Security Headers Configuration
# HTTPS enforcement (auto-enabled in production)
ENFORCE_HTTPS=false

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_ONLY=false


# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log File Path
LOG_FILE=./logs/trading_system.log

# Log Rotation
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5


# ============================================================================
# FEATURE FLAGS (Optional - can override config/feature_flags.py)
# ============================================================================

# Enable/disable advanced features (true/false)
# ENABLE_VSA=true
# ENABLE_WYCKOFF=true
# ENABLE_MARKET_PROFILE=true
# ENABLE_LIQUIDITY_ENGINEERING=true
# ENABLE_SMART_MONEY_DIVERGENCE=true
# ENABLE_MTF_CONFLUENCE=true
# ENABLE_ORDERBOOK_IMBALANCE=true
# ENABLE_INSTITUTIONAL_FLOW=true
# ENABLE_VOLATILITY_REGIME=true
# ENABLE_SEASONALITY=true
# ENABLE_ML_CALIBRATION=true
# ENABLE_DYNAMIC_TP=true
# ENABLE_DYNAMIC_SL=true
# ENABLE_CORRELATION_OPTIMIZATION=true
# ENABLE_ENHANCED_RISK_MANAGEMENT=true
# ENABLE_NEWS_SENTIMENT=true
# ENABLE_MICROSTRUCTURE=true
# ENABLE_BACKTESTING=true
# ENABLE_AB_TESTING=true
# ENABLE_PERFORMANCE_DASHBOARD=true


# ============================================================================
# MONITORING & ALERTING (Optional)
# ============================================================================

# Sentry Error Tracking
# Get DSN from: https://sentry.io/settings/projects/your-project/keys/
# Leave empty to disable Sentry in development
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Email Alerts (if implementing email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# ALERT_EMAIL_TO=alerts@yourdomain.com

# Slack Webhook (if implementing Slack notifications)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Telegram Bot (if implementing Telegram notifications)
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
